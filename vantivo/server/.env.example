# ============================================================================
# Vantivo SERVER environment
# The server is the ONLY place that holds the WaveSpeed API key.
# Copy this file to ".env" and fill WAVESPEED_API_KEY.
# ============================================================================

PORT=8787

# ---- Secret (server only — NEVER ships in the app) -------------------------
WAVESPEED_API_KEY=your_wavespeed_api_key_here

# ---- WaveSpeed base routes -------------------------------------------------
WAVESPEED_BASE_URL=https://api.wavespeed.ai
WAVESPEED_LLM_BASE_URL=https://llm.wavespeed.ai/v1

# ---- Chat + vision (cheap mini, multimodal: reads photos) ------------------
WAVESPEED_CHAT_URL=https://llm.wavespeed.ai/v1/chat/completions
WAVESPEED_CHAT_MODEL=openai/gpt-4o-mini
WAVESPEED_VISION_MODEL=openai/gpt-4o-mini

# ---- Image generation (1K) — low + medium quality presets ------------------
WAVESPEED_IMAGE_GENERATE_LOW_URL=https://api.wavespeed.ai/api/v3/wavespeed-ai/z-image/turbo
WAVESPEED_IMAGE_GENERATE_MEDIUM_URL=https://api.wavespeed.ai/api/v3/google/nano-banana-pro

# ---- Image editing (1K) — low + medium quality presets ---------------------
WAVESPEED_IMAGE_EDIT_LOW_URL=https://api.wavespeed.ai/api/v3/wavespeed-ai/qwen-image/edit
WAVESPEED_IMAGE_EDIT_MEDIUM_URL=https://api.wavespeed.ai/api/v3/google/nano-banana-pro/edit

# ---- Predictions polling ---------------------------------------------------
# Result is read from: ${WAVESPEED_PREDICTIONS_URL}/{id}/result
WAVESPEED_PREDICTIONS_URL=https://api.wavespeed.ai/api/v3/predictions

# ---- Image defaults --------------------------------------------------------
WAVESPEED_IMAGE_SIZE_1K=1024*1024
WAVESPEED_POLL_INTERVAL_MS=1200
WAVESPEED_POLL_TIMEOUT_MS=120000

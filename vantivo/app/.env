# ============================================================================
# Vantivo APP environment (working file)
# Only ROUTES live here (EXPO_PUBLIC_*). NO API KEYS in the app.
#
# For a physical phone, replace "localhost" with your computer's LAN IP
# (e.g. http://192.168.0.10:8787) so the device can reach the server.
# ============================================================================

# ---- Server base ------------------------------------------------------------
EXPO_PUBLIC_API_URL=http://localhost:8787
EXPO_PUBLIC_SERVER_URL=http://localhost:8787
EXPO_PUBLIC_HEALTH_URL=http://localhost:8787/health

# ---- Feature routes (proxied to wavespeed.ai by the server) ----------------
EXPO_PUBLIC_CHAT_URL=http://localhost:8787/api/chat
EXPO_PUBLIC_VISION_URL=http://localhost:8787/api/vision
EXPO_PUBLIC_IMAGE_GENERATE_URL=http://localhost:8787/api/image/generate
EXPO_PUBLIC_IMAGE_EDIT_URL=http://localhost:8787/api/image/edit
EXPO_PUBLIC_PDF_READ_URL=http://localhost:8787/api/pdf/read
EXPO_PUBLIC_PDF_MERGE_URL=http://localhost:8787/api/pdf/merge

# ---- App behaviour ----------------------------------------------------------
EXPO_PUBLIC_VANTIVO_MAX_TABS=10
EXPO_PUBLIC_CHAT_MODEL=openai/gpt-4o-mini
EXPO_PUBLIC_IMAGE_QUALITY_DEFAULT=low
